# Environment Configuration
# Copy this file to .env and update the values as needed

# Database Configuration
# Set DB_TYPE to 'sqlite' for SQLite database (recommended for development)
# Set DB_TYPE to 'postgresql' for PostgreSQL database (recommended for production)
DB_TYPE=sqlite
DB_PATH=app.db

# PostgreSQL Configuration (only needed if DB_TYPE=postgresql)
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dtv_inventory

# Alternative: Use DATABASE_URL for PostgreSQL (overrides individual DB_* settings)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Flask Configuration
SECRET_KEY=dev-key-please-change-in-production
JWT_SECRET_KEY=jwt-dev-key-change-in-production

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password